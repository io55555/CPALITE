# AI CLI Launcher 自动创建的示例 .gitignore
# 可按需删改以下规则。

# 系统文件
Thumbs.db
Desktop.ini

# 编辑器 / IDE
.vscode/
.idea/
*.swp
*.tmp
ai.txt
build.txt
buildlog/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node.js
node_modules/
npm-debug.log*
yarn-error.log*

# 构建输出
dist/
build/
out/
bin/
obj/

# 日志与本地缓存
*.log
.cache/
/runtime/

# 密钥与本地配置
.env
.env.*
*.local
